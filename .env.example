# env variablesMCP RAG Server
# ==========================================

# Configuration Ollama
API_KEY=ollama

# LLM
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=llama3

# Embedding
EMBED_BASE_URL=http://localhost:11434/v1
EMBED_MODEL=nomic-embed-text

# Chemin vers le certificat SSL (requis)
PATH_CA=/path/to/ca.crt

# Logs (optionnel)
PATH_LOGS=./logs

# ChromaDB - persistance directory (optionnel, default: ./chroma_db)
CHROMA_PERSIST_DIR=./chroma_db

# Embedding - Batch size (optionnel, default: 128)
EMBED_BATCH_SIZE=128

# Retrieval - Nombre de chunks par recherche (optionnel, default: 5)
RETRIEVAL_TOP_K=10

# LLM - Taille max du contexte (optionnel, default: 2000)
MAX_CONTEXT_CHARS=2000
MAX_EMBED_CHARS=2000

# Conversation - Contexte (optionnel, default: 5)
MAX_HISTORY_TURNS=5